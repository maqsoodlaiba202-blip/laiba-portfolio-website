      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 20px;
    }

    .hero h1 {
      font-size: 3rem;
      font-weight: 700;
    }

    .btn-custom {
      background: white;
      color: #333;
      border-radius: 30px;
      padding: 10px 25px;
      font-weight: 500;
      transition: 0.3s;
    }

    .btn-custom:hover {
      background: #eee;
    }

    section {
      padding: 70px 0;
    }

    .section-title {
      font-weight: 700;
      margin-bottom: 20px;
    }

    .card-box {
      background: white;
      padding: 20px;
      border-radius: 15px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.08);
      height: 100%;
    }

    footer {
      background: #111;
